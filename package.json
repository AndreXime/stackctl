{
   "name": "stackctl",
   "version": "0.7.0",
   "description": "TUI para gerenciar projetos e stacks Docker no terminal",
   "license": "ISC",
   "type": "module",
   "engines": {
      "node": ">=26"
   },
   "bin": {
      "stackctl": "./dist/cli.js"
   },
   "scripts": {
      "dev": "tsx watch src/cli.tsx",
      "start": "./dist/cli.js",
      "build": "node esbuild.config.mjs",
      "check": "biome check . && tsc --noEmit",
      "lint": "biome check --write . && tsc --noEmit",
      "format": "biome format --write ."
   },
   "dependencies": {
      "@inkjs/ui": "^2.0.0",
      "dotenv": "^17.4.2",
      "ink": "^7.0.6",
      "react": "^19.2.7"
   },
   "devDependencies": {
      "@biomejs/biome": "^2.5.0",
      "@types/node": "^25.9.3",
      "@types/react": "^19.2.17",
      "esbuild": "^0.28.1",
      "tsx": "^4.22.4",
      "typescript": "^6.0.3"
   }
}
