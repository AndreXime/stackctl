{
   "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
   "vcs": {
      "enabled": true,
      "clientKind": "git",
      "useIgnoreFile": true
   },
   "files": {
      "ignoreUnknown": false,
      "includes": ["src/**", "biome.json", "package.json", "tsconfig.json"]
   },
   "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 3
   },
   "linter": {
      "enabled": true,
      "rules": {
         "preset": "recommended"
      }
   },
   "javascript": {
      "formatter": {
         "quoteStyle": "single",
         "semicolons": "asNeeded"
      }
   },
   "assist": {
      "enabled": true,
      "actions": {
         "source": {
            "organizeImports": "on"
         }
      }
   }
}
